<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../lib/internal/Magento/Framework/ObjectManager/etc/config.xsd">
    <!-- Your existing preferences -->
    <preference for="Magento\Catalog\Model\Layer" type="Gopersonal\Magento\Model\Layer" />
    <preference for="Magento\Catalog\Model\Layer\ContextInterface" type="Magento\Catalog\Model\Layer\Context" />
    <preference for="Magento\Catalog\Model\Layer\ItemCollectionProviderInterface" type="Magento\Catalog\Model\Layer\Category\ItemCollectionProvider" />
    <preference for="Magento\Catalog\Model\Layer\StateKeyInterface" type="Magento\Catalog\Model\Layer\Category\StateKey" />
    <preference for="Magento\Catalog\Model\Layer\CollectionFilterInterface" type="Magento\Catalog\Model\Layer\Category\CollectionFilter" />
    <preference for="Magento\Catalog\Model\Layer\FilterableAttributeListInterface" type="Magento\Catalog\Model\Layer\Category\FilterableAttributeList" />
    <preference for="Magento\Catalog\Model\Layer\AvailabilityFlagInterface" type="Magento\Catalog\Model\Layer\Category\AvailabilityFlag" />

    <!-- Search Engine configuration -->
    <preference for="Magento\Search\Model\SearchEngine" type="Gopersonal\Magento\Plugin\SearchEngine" />
    
    <!-- Elasticsearch specific preferences -->
    <preference for="Magento\Framework\Search\AdapterInterface" 
                type="Magento\Elasticsearch\SearchAdapter\Adapter" />
    
    <!-- <type name="Gopersonal\Magento\Plugin\SearchEngine">
        <arguments>
            <argument name="engineResolver" xsi:type="object">Magento\Search\Model\EngineResolver</argument>
            <argument name="adapter" xsi:type="object">Magento\Elasticsearch\SearchAdapter\Adapter\Proxy</argument>
            <argument name="intervalFactory" xsi:type="object">Magento\Framework\Search\Dynamic\IntervalFactory</argument>
        </arguments>
    </type> -->

    <!-- Elasticsearch adapter configuration -->
    <!-- <virtualType name="Magento\Elasticsearch\SearchAdapter\Adapter" type="Magento\Elasticsearch\SearchAdapter\Adapter">
        <arguments>
            <argument name="connectionManager" xsi:type="object">Magento\Elasticsearch\SearchAdapter\ConnectionManager</argument>
            <argument name="queryContainer" xsi:type="object">Magento\Elasticsearch\SearchAdapter\QueryContainer</argument>
        </arguments>
    </virtualType> -->

    <preference for="Magento\Search\Model\SearchEngine"
                type="Gopersonal\Magento\Plugin\SearchEngine" />

    <type name="Magento\Catalog\Model\Layer\Filter\AbstractFilter">
        <plugin name="gopersonal_layered_navigation"
                type="Gopersonal\Magento\Plugin\LayeredNavigationPlugin"/>
    </type>
    
    <type name="Gopersonal\Magento\Observer\BeforeSearchRequest">
        <arguments>
            <argument name="request" xsi:type="object">Magento\Framework\App\RequestInterface</argument>
        </arguments>
    </type>

    <type name="Magento\Catalog\Model\Product">
        <plugin name="gopersonal_product_url" type="Gopersonal\Magento\Plugin\ProductUrlPlugin" />
    </type>

    <!-- <type name="Magento\Catalog\Model\Layer">
        <plugin name="debug_layer_collection" type="Gopersonal\Magento\Plugin\LayerPlugin" />
    </type> -->

</config>